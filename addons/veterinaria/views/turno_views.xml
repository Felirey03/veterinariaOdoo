<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- VISTA ÁRBOL (Lista) -->
    <record id="view_veterinaria_turno_tree" model="ir.ui.view">
        <field name="name">veterinaria.turno.tree</field>
        <field name="model">veterinaria.turno</field>
        <field name="arch" type="xml">
            <tree>
                <field name="mascota_id"/>
                <field name="veterinario_id"/>
                <field name="fecha_hora"/>
                <field name="estado" widget="badge" 
                    decoration-info="estado == 'confirmed'" 
                    decoration-success="estado == 'done'" 
                    decoration-danger="estado == 'cancel'"
                    decoration-warning="estado == 'in_consultation'"/>
            </tree>
        </field>
    </record>

    <record id="view_veterinaria_turno_search" model="ir.ui.view">
        <field name="name">veterinaria.turno.search</field>
        <field name="model">veterinaria.turno</field>
        <field name="arch" type="xml">
            <search string="Buscar Turnos">
                <field name="mascota_id"/>
                <field name="veterinario_id"/>
                <field name="estado"/>
                <field name="fecha_hora"/>
                <filter name="filtro_hoy" string="Hoy" domain="[('fecha_hora', '&gt;=', context_today()), ('fecha_hora', '&lt;', context_today() + relativedelta(days=1))]"/>
                <filter name="filtro_confirmados" string="Confirmados" domain="[('estado', '=', 'confirmed')]"/>
                <filter name="filtro_realizados" string="Realizados" domain="[('estado', '=', 'done')]"/>
                <separator/>
                <filter name="group_veterinario" string="Veterinario" context="{'group_by': 'veterinario_id'}"/>
                <filter name="group_estado" string="Estado" context="{'group_by': 'estado'}"/>
            </search>
        </field>
    </record>

    <!-- VISTA FORMULARIO -->
    <record id="veterinaria_turno_view_form" model="ir.ui.view">
        <field name="name">veterinaria.turno.view.form</field>
        <field name="model">veterinaria.turno</field>
        <field name="arch" type="xml">
            <form string="Turno">
                <header>
                    <button name="action_confirm" string="Confirmar" type="object" class="oe_highlight" invisible="estado != 'draft'"/>
                    <button name="action_cancel" string="Cancelar Turno" type="object" invisible="estado in ['done', 'cancel']"/>
                    <button name="iniciar_consulta" string="Iniciar Consulta" type="object" class="oe_highlight" invisible="estado != 'confirmed'"/>
                    <button name="action_whatsapp_reminder" string="WhatsApp Recordatorio" type="object" icon="fa-whatsapp" class="btn-success" invisible="estado == 'cancel' or not mascota_id or not fecha_hora"/>
                    <field name="estado" widget="statusbar" statusbar_visible="draft,confirmed,in_consultation,done"/>

                </header>
                <sheet>
                    <group>
                        <group string="Paciente y Profesional">
                            <field name="mascota_id"/>
                            <field name="veterinario_id"/>
                        </group>
                        <group string="Programación">
                            <field name="fecha_hora"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>


    <record id="veterinaria_turno_view_calendar" model="ir.ui.view">
        <field name="name">veterinaria.turno.view.calendar</field>
        <field name="model">veterinaria.turno</field>
        <field name="arch" type="xml">
            <calendar string="Turnos" date_start="fecha_hora" color="veterinario_id" mode="month" event_open_popup="true">
                <field name="mascota_id"/>
                <field name="veterinario_id" filters="1"/>
                <field name="estado" filters="1"/>
            </calendar>
        </field>
    </record>

</odoo>
<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_veterinaria_mascota_tree" model="ir.ui.view">
        <field name="name">veterinaria.mascota.tree</field>
        <field name="model">veterinaria.mascota</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="especie"/>
                <field name="raza"/>
                <field name="edad"/>
                <field name="propietario_id"/>
            </tree>
        </field>
    </record>

    <record id="view_veterinaria_mascota_search" model="ir.ui.view">
        <field name="name">veterinaria.mascota.search</field>
        <field name="model">veterinaria.mascota</field>
        <field name="arch" type="xml">
            <search string="Buscar Mascotas">
                <field name="name"/>
                <field name="especie"/>
                <field name="raza"/>
                <field name="propietario_id"/>
                <filter name="sin_propietario" string="Sin responsable" domain="[('propietario_id', '=', False)]"/>
                <filter name="con_vacunas_vencidas" string="Vacunas vencidas" domain="[('tiene_vacunas_vencidas', '=', True)]"/>
                <separator/>
                <filter name="group_especie" string="Especie" context="{'group_by': 'especie'}"/>
                <filter name="group_responsable" string="Responsable" context="{'group_by': 'propietario_id'}"/>
            </search>
        </field>
    </record>

    <record id="veterinaria_mascota_view_form" model="ir.ui.view">
        <field name="name">veterinaria.mascota.view.form</field>
        <field name="model">veterinaria.mascota</field>
        <field name="arch" type="xml">
            <form string="Mascota">
                <sheet>
                    <field name="tiene_vacunas_vencidas" invisible="1"/>
                    <div class="alert alert-danger text-center" role="alert" invisible="not tiene_vacunas_vencidas">
                        <strong>ATENCIÓN:</strong> Esta mascota tiene <strong>vacunas o refuerzos vencidos</strong>. Revisar pestaña "Plan Sanitario".
                    </div>

                    <div class="oe_title">
                        <label for="name" string="Nombre de la Mascota"/>
                        <h1>
                            <field name="name" placeholder="Ej: Rocky"/>
                        </h1>
                    </div>
                    
                    <group>
                        <group string="Información General">
                            <field name="especie"/>
                            <field name="raza"/>
                            <field name="sexo"/>
                            <field name="ultimo_peso" readonly="1"/>
                        </group>
                        <group string="Identidad y Edad">
                            <field name="fecha_nacimiento"/>
                            <field name="edad" readonly="1"/>
                        </group>
                    </group>

                    <group>
                        <group string="Responsable">
                            <field name="propietario_id"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Alertas y Notas Médicas" name="medical_alerts_page">
                            <separator string="Alertas Críticas (Alergias, Enfermedades, Conducta)"/>
                            <field name="alerta_medica" placeholder="Ej: Alérgico a la Penicilina. Sufre de convulsiones..."/>
                        </page>
                        <page string="Plan Sanitario (Vacunas)" name="vaccine_page">
                            <field name="vacuna_ids">
                                <tree editable="bottom">
                                    <field name="producto_id"/>
                                    <field name="fecha_aplicacion"/>
                                    <field name="fecha_refuerzo" widget="remaining_days" decoration-danger="fecha_refuerzo &lt; current_date"/>
                                    <field name="veterinario_id" invisible="1"/>
                                    <field name="observaciones"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
